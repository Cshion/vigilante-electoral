# ===================
# SENSITIVE FILES - DO NOT COMMIT
# ===================

# Environment variables (CRITICAL)
.env
.env.local
.env.*.local
.env.production
.env.development

# ===================
# PYTHON / BACKEND
# ===================

# Virtual environments
venv/
env/
.venv/
.env/

# Byte-compiled files

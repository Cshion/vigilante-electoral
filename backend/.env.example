# =============================================================================
# Vigilante Electoral - Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
DEBUG=True

# -----------------------------------------------------------------------------
# CORS Configuration - REQUIRED for production
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins.
# Examples:
#   - Single origin: ALLOWED_ORIGINS=https://myapp.vercel.app
#   - Multiple origins: ALLOWED_ORIGINS=https://app.com,https://api.com,http://localhost:3000
#   - Allow all (development only): ALLOWED_ORIGINS=*
#
# WARNING: If ALLOWED_ORIGINS is empty and DEBUG=false, all CORS requests will be blocked.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Optional: Regex pattern for dynamic origins (e.g., Vercel preview deployments)
# This allows matching multiple subdomains without listing them all.
# Example: https://vigilante-electoral.*\.vercel\.app
CORS_ORIGIN_REGEX=

# -----------------------------------------------------------------------------
# Database Configuration (Supabase)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
CRON_SECRET=generate-a-secure-random-string
